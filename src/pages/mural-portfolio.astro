---
import BaseLayout from '../layouts/BaseLayout.astro';
import { featuredMuralGallery, processMuralGallery } from '../data/murals';
---

<BaseLayout title="Mural Portfolio">
  <div class="product-stack">
    <a class="back-link" href="/murals">← Back to murals</a>

    <section class="section-card compact-card">
      <p class="meta-line">Mural portfolio</p>
      <h1>Mural portfolio</h1>
      <p class="section-intro">
        A broader look at concept-led mural work, finished wall pieces, and the process behind how ideas move from
        surface to completed artwork.
      </p>
    </section>

    <section class="section-card compact-card">
      <h2>Featured wall work</h2>
      <p class="section-intro">
        Finished examples and concept-driven pieces that show the style, linework, and visual atmosphere COPE brings
        into a space.
      </p>

      <div class="gallery-grid" aria-label="Mural portfolio gallery">
        {featuredMuralGallery.map((image, index) => (
          <article class="gallery-card">
            <button
              type="button"
              class="gallery-button"
              data-gallery-src={image.src}
              data-gallery-alt={image.alt}
              aria-label={`Open larger image: ${image.caption}`}
            >
              <span class="media-frame gallery-frame">
                <img src={image.src} alt={image.alt} loading={index > 1 ? 'lazy' : undefined} />
              </span>
            </button>
            <span class="thumb-caption">{image.caption}</span>
          </article>
        ))}
      </div>
    </section>

    {processMuralGallery.length > 0 && (
      <section class="section-card compact-card">
        <h2>Process snapshots</h2>
        <p class="section-intro">
          A few behind-the-scenes images showing how a mural starts to take shape before the finished piece is complete.
        </p>

        <div class="gallery-grid process-grid" aria-label="Mural process gallery">
          {processMuralGallery.map((image) => (
            <article class="gallery-card">
              <button
                type="button"
                class="gallery-button"
                data-gallery-src={image.src}
                data-gallery-alt={image.alt}
                aria-label={`Open larger image: ${image.caption}`}
              >
                <span class="media-frame gallery-frame">
                  <img src={image.src} alt={image.alt} loading="lazy" />
                </span>
              </button>
              <span class="thumb-caption">{image.caption}</span>
            </article>
          ))}
        </div>

        <p class="form-note">
          Short process clips or GIFs can sit naturally in this section later without making the main Murals page feel overloaded.
        </p>
      </section>
    )}
  </div>

  <div class="lightbox" id="mural-lightbox" hidden>
    <div class="lightbox-backdrop" data-mural-lightbox-close></div>
    <div class="lightbox-dialog" role="dialog" aria-modal="true" aria-label="Larger view of mural image">
      <button type="button" class="lightbox-close" id="mural-lightbox-close" aria-label="Close larger mural image view">×</button>
      <div class="lightbox-frame">
        <img id="mural-lightbox-image" src="" alt="" />
      </div>
    </div>
  </div>

  <script is:inline>
    const muralLightbox = document.getElementById('mural-lightbox');
    const muralLightboxImage = document.getElementById('mural-lightbox-image');
    const muralLightboxClose = document.getElementById('mural-lightbox-close');
    const muralCloseElements = document.querySelectorAll('[data-mural-lightbox-close]');
    const muralButtons = document.querySelectorAll('[data-gallery-src]');

    const openMuralLightbox = (src, alt) => {
      if (!muralLightbox || !muralLightboxImage) return;

      muralLightboxImage.setAttribute('src', src);
      muralLightboxImage.setAttribute('alt', alt || '');
      muralLightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeMuralLightbox = () => {
      if (!muralLightbox) return;

      muralLightbox.hidden = true;
      document.body.style.overflow = '';
    };

    muralButtons.forEach((button) => {
      button.addEventListener('click', () => {
        const src = button.getAttribute('data-gallery-src');
        const alt = button.getAttribute('data-gallery-alt') || '';
        if (!src) return;
        openMuralLightbox(src, alt);
      });
    });

    muralCloseElements.forEach((element) => {
      element.addEventListener('click', closeMuralLightbox);
    });

    if (muralLightboxClose) {
      muralLightboxClose.addEventListener('click', closeMuralLightbox);
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && muralLightbox && !muralLightbox.hidden) {
        closeMuralLightbox();
      }
    });
  </script>
</BaseLayout>
