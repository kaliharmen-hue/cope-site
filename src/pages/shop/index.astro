---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const artworks = await getCollection('products', ({ id }) => id.startsWith('original-art/'));
---

<BaseLayout title="Shop">
  <p class="eyebrow">Original artwork</p>
  <h1>Shop</h1>
  <p>
    The shop launches with a small selection of original framed artworks. Apparel, digital work, and prints can be added
    later as the collection expands.
  </p>

  <div class="section-grid">
    {artworks.map((artwork) => (
      <article class="section-card">
        <div class="media-frame shop-art">
          <img src="/images/artworks/cope-always.jpg" alt={`${artwork.data.title} placeholder artwork image`} />
        </div>
        <h2>{artwork.data.title}</h2>
        <p><strong>Status:</strong> {artwork.data.status}</p>
        <p><strong>Price:</strong> {artwork.data.price}</p>
        <p><strong>Medium:</strong> {artwork.data.medium}</p>
        <p><strong>Dimensions:</strong> {artwork.data.dimensions}</p>
        <p><strong>Framing:</strong> {artwork.data.framing}</p>
        <p>{artwork.body}</p>
        <p>
          <a class="button secondary" href="/contact">Enquire about this piece</a>
        </p>
      </article>
    ))}
  </div>
</BaseLayout>
