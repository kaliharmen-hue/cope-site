---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Shop">
  <p class="eyebrow">Shop</p>
  <h1>Shop</h1>
  <p class="section-intro">
    Explore the original art collection, or head into apparel to preview the first COPE and Agie tee designs as the
    first drop takes shape.
  </p>

  <div class="mini-grid shop-overview-grid">
    <article class="section-card compact-card">
      <p class="meta-line">Shop Art</p>
      <h2>Original artwork</h2>
      <p>
        Browse the current framed pieces, open each work in more detail, and enquire directly about the originals that
        catch your eye.
      </p>
      <p><a class="button secondary" href="/shop/art/">Browse original art</a></p>
    </article>

    <article class="section-card compact-card">
      <p class="meta-line">Shop Apparel</p>
      <h2>First tee designs</h2>
      <p>
        Preview the early apparel concepts and register interest in the COPE and Agie designs as the first drop moves
        closer.
      </p>
      <p><a class="button secondary" href="/shop/apparel/">Browse apparel</a></p>
    </article>
  </div>
</BaseLayout>
