---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const artworks = await getCollection('products', ({ id }) => id.startsWith('original-art/'));
const apparelItems = [
  {
    title: 'COPE Tee / Black',
    image: '/images/apparel/cope-black.png',
    alt: 'COPE t-shirt design on a black shirt',
    status: 'Coming soon',
    description: 'A bold COPE graphic on black, built to feel clean, graphic, and easy to wear as part of the first apparel drop.',
  },
  {
    title: 'COPE Tee / White',
    image: '/images/apparel/cope-white.png',
    alt: 'COPE t-shirt design on a white shirt',
    status: 'Coming soon',
    description: 'The same COPE design on white for a brighter, lighter version of the first drop with a strong graphic feel.',
  },
  {
    title: 'Agie Tee / Black',
    image: '/images/apparel/agie-black.png',
    alt: 'Agie t-shirt design on a black shirt',
    status: 'Coming soon',
    description: 'An Agie design on black that keeps the line sharp and wearable while still feeling rooted in the brand’s street-led personality.',
  },
  {
    title: 'Agie Tee / White',
    image: '/images/apparel/agie-white.png',
    alt: 'Agie t-shirt design on a white shirt',
    status: 'Coming soon',
    description: 'A white-shirt version of the Agie design, giving the first apparel range another clean and more open colourway option.',
  },
];
---

<BaseLayout title="Shop">
  <p class="eyebrow">Original artwork</p>
  <h1>Shop</h1>
  <p>
    The shop launches with a small selection of original framed artworks. Apparel, digital work, and prints can be added
    later as the collection expands.
  </p>

  <div class="shop-grid">
    {artworks.map((artwork) => (
      <article class="section-card shop-card">
        <a class="shop-card-link" href={`/shop/${artwork.slug}/`}>
          <div class="media-frame shop-art">
            <img src={artwork.data.primaryImage} alt={artwork.data.imageAlt || artwork.data.title} />
          </div>
          <div class="shop-copy">
            <h2>{artwork.data.title}</h2>
            <div class="product-meta">
              <p><strong>Status:</strong> {artwork.data.status}</p>
              <p><strong>Price:</strong> {artwork.data.price}</p>
              <p><strong>Medium:</strong> {artwork.data.medium}</p>
              <p><strong>Dimensions:</strong> {artwork.data.dimensions}</p>
              <p><strong>Framing:</strong> {artwork.data.framing}</p>
            </div>
            <p>{artwork.body}</p>
            <p class="shop-link-note">View piece</p>
          </div>
        </a>
      </article>
    ))}
  </div>

  <section class="shop-section">
    <p class="eyebrow">Apparel</p>
    <h2>First tee designs</h2>
    <p class="section-intro">
      The first apparel pieces are now taking shape, with early COPE and Agie t-shirt designs ready to preview as the
      first drop develops.
    </p>

    <div class="shop-grid">
      {apparelItems.map((item) => (
        <article class="section-card shop-card">
          <div class="shop-card-link">
            <div class="media-frame shop-art shop-apparel-art">
              <img src={item.image} alt={item.alt} />
            </div>
            <div class="shop-copy">
              <h2>{item.title}</h2>
              <div class="product-meta">
                <p><strong>Status:</strong> {item.status}</p>
              </div>
              <p>{item.description}</p>
              <p><a class="button secondary" href="/contact">Register interest</a></p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
