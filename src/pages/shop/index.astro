---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { apparelItems } from '../../data/apparel';

const artworks = await getCollection('products', ({ id }) => id.startsWith('original-art/'));
---

<BaseLayout title="Shop">
  <p class="eyebrow">Shop</p>
  <h1>Shop</h1>
  <p class="section-intro">
    Explore the original art collection, or head into apparel to preview the first COPE and Agie tee designs as the
    first drop takes shape.
  </p>

  <div class="mini-grid shop-overview-grid">
    <article class="section-card compact-card">
      <p class="meta-line">Shop Art</p>
      <h2>Original artwork</h2>
      <p>
        Browse the current framed pieces, open each work in more detail, and enquire directly about the originals that
        catch your eye.
      </p>
      <p><a class="button secondary" href="#shop-art">Browse original art</a></p>
    </article>

    <article class="section-card compact-card">
      <p class="meta-line">Shop Apparel</p>
      <h2>First tee designs</h2>
      <p>
        Preview the early apparel concepts and register interest in the COPE and Agie designs as the first drop moves
        closer.
      </p>
      <p><a class="button secondary" href="#shop-apparel">Browse apparel</a></p>
    </article>
  </div>

  <section class="shop-section" id="shop-art">
    <p class="eyebrow">Shop Art</p>
    <h2>Original artwork</h2>
    <p class="section-intro">
      The current collection focuses on framed original works designed to bring colour, personality, and strong visual
      presence into a space.
    </p>

    <div class="shop-grid">
      {artworks.map((artwork) => (
        <article class="section-card shop-card">
          <a class="shop-card-link" href={`/shop/${artwork.slug}/`}>
            <div class="media-frame shop-art">
              <img src={artwork.data.primaryImage} alt={artwork.data.imageAlt || artwork.data.title} />
            </div>
            <div class="shop-copy">
              <h2>{artwork.data.title}</h2>
              <div class="product-meta">
                <p><strong>Status:</strong> {artwork.data.status}</p>
                <p><strong>Price:</strong> {artwork.data.price}</p>
                <p><strong>Medium:</strong> {artwork.data.medium}</p>
                <p><strong>Dimensions:</strong> {artwork.data.dimensions}</p>
                <p><strong>Framing:</strong> {artwork.data.framing}</p>
              </div>
              <p>{artwork.body}</p>
              <p class="shop-link-note">View piece</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>

  <section class="shop-section" id="shop-apparel">
    <p class="eyebrow">Shop Apparel</p>
    <h2>First tee designs</h2>
    <p class="section-intro">
      The first apparel drop is starting to take shape, with early COPE and Agie tee designs now ready to preview.
    </p>

    <div class="shop-grid">
      {apparelItems.map((item) => (
        <article class="section-card shop-card">
          <div class="shop-card-link">
            <div class="media-frame shop-art shop-apparel-art">
              <img src={item.image} alt={item.alt} />
            </div>
            <div class="shop-copy">
              <h2>{item.title}</h2>
              <div class="product-meta">
                <p><strong>Status:</strong> {item.status}</p>
              </div>
              <p>{item.description}</p>
              <p><a class="button secondary" href="/contact">Register interest</a></p>
            </div>
          </div>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
