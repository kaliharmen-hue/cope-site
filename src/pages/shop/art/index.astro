---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const artworks = await getCollection('products', ({ id }) => id.startsWith('original-art/'));
---

<BaseLayout title="Shop Art">
  <p class="eyebrow">Shop Art</p>
  <h1>Original artwork</h1>
  <p class="section-intro">
    Browse the current framed originals, open each work in more detail, and enquire directly about the pieces that
    catch your eye.
  </p>

  <p class="button-row">
    <a class="button secondary" href="/shop/">Back to shop overview</a>
  </p>

  <section class="shop-section">
    <div class="shop-grid">
      {artworks.map((artwork) => (
        <article class="section-card shop-card">
          <a class="shop-card-link" href={`/shop/${artwork.slug}/`}>
            <div class="media-frame shop-art">
              <img src={artwork.data.primaryImage} alt={artwork.data.imageAlt || artwork.data.title} />
            </div>
            <div class="shop-copy">
              <h2>{artwork.data.title}</h2>
              <div class="product-meta">
                <p><strong>Status:</strong> {artwork.data.status}</p>
                <p><strong>Price:</strong> {artwork.data.price}</p>
                <p><strong>Medium:</strong> {artwork.data.medium}</p>
                <p><strong>Dimensions:</strong> {artwork.data.dimensions}</p>
                <p><strong>Framing:</strong> {artwork.data.framing}</p>
              </div>
              <p>{artwork.body}</p>
              <p class="shop-link-note">View piece</p>
            </div>
          </a>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
