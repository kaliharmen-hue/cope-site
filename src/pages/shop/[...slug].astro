---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const artworks = await getCollection('products', ({ id }) => id.startsWith('original-art/'));

  return artworks.map((artwork) => ({
    params: { slug: artwork.slug },
    props: { artwork },
  }));
}

const { artwork } = Astro.props;
const { Content } = await render(artwork);
const galleryImages = artwork.data.galleryImages?.length
  ? artwork.data.galleryImages
  : [{ src: artwork.data.primaryImage, alt: artwork.data.imageAlt || artwork.data.title }];
const firstImage = galleryImages[0];
---

<BaseLayout title={artwork.data.title}>
  <div class="product-stack">
    <p class="eyebrow">Original artwork</p>
    <p><a class="back-link" href="/shop/">Back to shop</a></p>

    <div class="product-layout">
      <section class="section-card compact-card">
        <div class="product-gallery">
          <button
            type="button"
            id="product-main-link"
            class="media-frame product-main-image"
            data-lightbox-trigger
            aria-label="Open larger artwork image"
          >
            <img id="product-main-image" src={firstImage.src} alt={firstImage.alt} />
          </button>

          {galleryImages.length > 1 && (
            <div class="product-thumbnails" aria-label="Artwork gallery">
              {galleryImages.map((image, index) => (
                <button
                  type="button"
                  class={`thumb-button ${index === 0 ? 'is-active' : ''}`}
                  data-src={image.src}
                  data-alt={image.alt}
                >
                  <span class="media-frame thumb-frame">
                    <img src={image.src} alt={image.alt} />
                  </span>
                  {image.caption && <span class="thumb-caption">{image.caption}</span>}
                </button>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="section-card compact-card">
        <h1>{artwork.data.title}</h1>
        <div class="product-meta">
          <p><strong>Status:</strong> {artwork.data.status}</p>
          <p><strong>Price:</strong> {artwork.data.price}</p>
          <p><strong>Medium:</strong> {artwork.data.medium}</p>
          <p><strong>Dimensions:</strong> {artwork.data.dimensions}</p>
          <p><strong>Framing:</strong> {artwork.data.framing}</p>
        </div>
        <Content />
        <div class="button-row">
          <a class="button primary" href="/contact">Enquire about this piece</a>
          <button type="button" class="button secondary" id="open-lightbox-button">Open larger image</button>
        </div>
      </section>
    </div>
  </div>

  <div class="lightbox" id="artwork-lightbox" hidden>
    <div class="lightbox-backdrop" data-lightbox-close></div>
    <div class="lightbox-dialog" role="dialog" aria-modal="true" aria-label={`Larger view of ${artwork.data.title}`}>
      <button type="button" class="lightbox-close" id="lightbox-close" aria-label="Close larger image view">×</button>
      <div class="lightbox-frame">
        <img id="lightbox-image" src={firstImage.src} alt={firstImage.alt} />
      </div>
    </div>
  </div>

  <script is:inline>
    const mainImage = document.getElementById('product-main-image');
    const mainLink = document.getElementById('product-main-link');
    const thumbButtons = document.querySelectorAll('.thumb-button');
    const lightbox = document.getElementById('artwork-lightbox');
    const lightboxImage = document.getElementById('lightbox-image');
    const openLightboxButton = document.getElementById('open-lightbox-button');
    const lightboxClose = document.getElementById('lightbox-close');
    const lightboxCloseElements = document.querySelectorAll('[data-lightbox-close]');

    const openLightbox = () => {
      if (!lightbox || !lightboxImage || !mainImage) return;

      lightboxImage.setAttribute('src', mainImage.getAttribute('src') || '');
      lightboxImage.setAttribute('alt', mainImage.getAttribute('alt') || '');
      lightbox.hidden = false;
      document.body.style.overflow = 'hidden';
    };

    const closeLightbox = () => {
      if (!lightbox) return;

      lightbox.hidden = true;
      document.body.style.overflow = '';
    };

    if (mainLink) {
      mainLink.addEventListener('click', openLightbox);
    }

    if (openLightboxButton) {
      openLightboxButton.addEventListener('click', openLightbox);
    }

    if (lightboxCloseElements.length) {
      lightboxCloseElements.forEach((element) => {
        element.addEventListener('click', closeLightbox);
      });
    }

    if (lightboxClose) {
      lightboxClose.addEventListener('click', closeLightbox);
    }

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && lightbox && !lightbox.hidden) {
        closeLightbox();
      }
    });

    if (mainImage && mainLink && thumbButtons.length) {
      thumbButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const src = button.getAttribute('data-src');
          const alt = button.getAttribute('data-alt') || '';
          if (!src) return;

          mainImage.setAttribute('src', src);
          mainImage.setAttribute('alt', alt);
          if (lightboxImage) {
            lightboxImage.setAttribute('src', src);
            lightboxImage.setAttribute('alt', alt);
          }

          thumbButtons.forEach((item) => item.classList.remove('is-active'));
          button.classList.add('is-active');
        });
      });
    }
  </script>
</BaseLayout>
