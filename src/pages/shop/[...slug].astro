---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const artworks = await getCollection('products', ({ id }) => id.startsWith('original-art/'));

  return artworks.map((artwork) => ({
    params: { slug: artwork.slug },
    props: { artwork },
  }));
}

const { artwork } = Astro.props;
const { Content } = await render(artwork);
const galleryImages = artwork.data.galleryImages?.length
  ? artwork.data.galleryImages
  : [{ src: artwork.data.primaryImage, alt: artwork.data.imageAlt || artwork.data.title }];
const firstImage = galleryImages[0];
---

<BaseLayout title={artwork.data.title}>
  <div class="product-stack">
    <p class="eyebrow">Original artwork</p>
    <p><a class="back-link" href="/shop/">Back to shop</a></p>

    <div class="product-layout">
      <section class="section-card compact-card">
        <div class="product-gallery">
          <a
            id="product-main-link"
            class="media-frame product-main-image"
            href={firstImage.src}
            target="_blank"
            rel="noreferrer"
          >
            <img id="product-main-image" src={firstImage.src} alt={firstImage.alt} />
          </a>

          {galleryImages.length > 1 && (
            <div class="product-thumbnails" aria-label="Artwork gallery">
              {galleryImages.map((image, index) => (
                <button
                  type="button"
                  class={`thumb-button ${index === 0 ? 'is-active' : ''}`}
                  data-src={image.src}
                  data-alt={image.alt}
                >
                  <span class="media-frame thumb-frame">
                    <img src={image.src} alt={image.alt} />
                  </span>
                  {image.caption && <span class="thumb-caption">{image.caption}</span>}
                </button>
              ))}
            </div>
          )}
        </div>
      </section>

      <section class="section-card compact-card">
        <h1>{artwork.data.title}</h1>
        <p><strong>Status:</strong> {artwork.data.status}</p>
        <p><strong>Price:</strong> {artwork.data.price}</p>
        <p><strong>Medium:</strong> {artwork.data.medium}</p>
        <p><strong>Dimensions:</strong> {artwork.data.dimensions}</p>
        <p><strong>Framing:</strong> {artwork.data.framing}</p>
        <Content />
        <div class="button-row">
          <a class="button primary" href="/contact">Enquire about this piece</a>
          <a class="button secondary" href={firstImage.src} target="_blank" rel="noreferrer">Open larger image</a>
        </div>
      </section>
    </div>
  </div>

  <script is:inline>
    const mainImage = document.getElementById('product-main-image');
    const mainLink = document.getElementById('product-main-link');
    const thumbButtons = document.querySelectorAll('.thumb-button');

    if (mainImage && mainLink && thumbButtons.length) {
      thumbButtons.forEach((button) => {
        button.addEventListener('click', () => {
          const src = button.getAttribute('data-src');
          const alt = button.getAttribute('data-alt') || '';
          if (!src) return;

          mainImage.setAttribute('src', src);
          mainImage.setAttribute('alt', alt);
          mainLink.setAttribute('href', src);

          thumbButtons.forEach((item) => item.classList.remove('is-active'));
          button.classList.add('is-active');
        });
      });
    }
  </script>
</BaseLayout>
