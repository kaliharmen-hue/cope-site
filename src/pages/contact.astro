---
import BaseLayout from '../layouts/BaseLayout.astro';
import { frontmatter } from '../content/pages/contact.md';
---

<BaseLayout title={frontmatter.title}>
  <section class="contact-stack">
    <div class="section-intro">
      <p class="eyebrow">COPE Team</p>
      <h1>{frontmatter.title}</h1>
      <p>
        If you are interested in original artwork, a mural, a commission, or a general collaboration enquiry, use the
        form below and we will come back to you as soon as possible.
      </p>
      <p>
        This keeps the main inbox off the page, which is a better starting point for spam protection than publishing a
        visible email address.
      </p>
    </div>

    <div class="contact-grid">
      <section class="section-card compact-card">
        <p class="meta-line">What to include</p>
        <h2>Helpful details</h2>
        <ul>
          <li>What you are enquiring about: original art, mural, commission, or general project</li>
          <li>Approximate size, budget, or scale if known</li>
          <li>Where the work will be used</li>
          <li>Any important dates or timing</li>
          <li>Reference links if they help explain the idea</li>
        </ul>
      </section>

      <section class="section-card compact-card">
        <p class="meta-line">Enquiry form</p>
        <h2>Start an enquiry</h2>
        <form class="site-form" method="POST" action="https://formspree.io/f/maqazbgk">
          <div class="field-row">
            <div class="field">
              <label for="name">Name</label>
              <input id="name" name="name" type="text" autocomplete="name" required />
            </div>

            <div class="field">
              <label for="email">Email</label>
              <input id="email" name="email" type="email" autocomplete="email" required />
            </div>
          </div>

          <div class="field-row">
            <div class="field">
              <label for="enquiry-type">Enquiry type</label>
              <select id="enquiry-type" name="enquiry_type" required>
                <option value="">Select one</option>
                <option value="original-art">Original art</option>
                <option value="murals">Murals</option>
                <option value="commissions">Commissions</option>
                <option value="general">General enquiry</option>
              </select>
            </div>
          </div>

          <div class="field">
            <label for="subject">Subject</label>
            <input id="subject" name="subject" type="text" required />
          </div>

          <div class="field">
            <label for="message">Message</label>
            <textarea id="message" name="message" rows="7" required></textarea>
          </div>

          <input type="hidden" name="_subject" value="COPE website enquiry" />

          <div class="form-trap" aria-hidden="true">
            <label for="company">Company</label>
            <input id="company" name="company" type="text" tabindex="-1" autocomplete="off" />
          </div>

          <div class="button-row">
            <button class="button primary" type="submit">Send enquiry</button>
          </div>
        </form>
      </section>
    </div>
  </section>
</BaseLayout>
