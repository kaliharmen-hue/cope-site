---
interface Props {
  title: string;
}

const { title } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  { href: '/shop/', label: 'Shop' },
  { href: '/murals', label: 'Murals' },
  { href: '/commissions', label: 'Commissions' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/journal/', label: 'Journal' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe7;
        --text: #18120f;
        --muted: #5c5149;
        --line: #d8cabd;
        --accent: #de5a2a;
        --accent-dark: #a83a16;
        --surface: rgba(255, 252, 247, 0.82);
        --max: 1080px;
      }

      :global(*) {
        box-sizing: border-box;
      }

      :global(body) {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(222, 90, 42, 0.14), transparent 20rem),
          radial-gradient(circle at bottom right, rgba(24, 18, 15, 0.06), transparent 26rem),
          linear-gradient(180deg, #fbf7f1 0%, var(--bg) 100%);
      }

      :global(a) {
        color: inherit;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
        background: rgba(247, 242, 232, 0.9);
        border-bottom: 1px solid var(--line);
      }

      .header-inner,
      .page-shell,
      .site-footer {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }

      .header-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 0;
      }

      .brand {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        text-decoration: none;
      }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
      }

      .nav a {
        text-decoration: none;
        color: var(--muted);
      }

      .nav a:hover {
        color: var(--text);
      }

      .page-shell {
        padding: 2rem 0 3rem;
      }

      .page-card {
        background: var(--surface);
        border: 1px solid rgba(217, 204, 191, 0.9);
        border-radius: 20px;
        padding: 1.25rem;
        box-shadow: 0 12px 28px rgba(23, 20, 18, 0.04);
      }

      .eyebrow {
        display: inline-block;
        margin: 0 0 0.85rem;
        padding: 0.32rem 0.6rem;
        border-radius: 999px;
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
        background: rgba(222, 90, 42, 0.1);
      }

      :global(h1),
      :global(h2),
      :global(h3) {
        line-height: 1.06;
        margin-top: 0;
      }

      :global(h1) {
        font-size: clamp(2.7rem, 6.3vw, 5.4rem);
        max-width: 11ch;
        margin-bottom: 1.1rem;
        letter-spacing: -0.03em;
      }

      :global(h2) {
        font-size: clamp(1.7rem, 3vw, 2.35rem);
        margin-bottom: 0.7rem;
        letter-spacing: -0.02em;
      }

      :global(h3) {
        font-size: 1.1rem;
        margin-bottom: 0.4rem;
      }

      :global(p),
      :global(li) {
        font-size: 1.03rem;
        line-height: 1.68;
        color: var(--muted);
      }

      :global(ul) {
        padding-left: 1.2rem;
      }

      .site-footer {
        padding: 0 0 2rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      :global(.button-row) {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin: 1.35rem 0 0;
      }

      :global(.button) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: 0.8rem 1.28rem;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid var(--text);
        font-size: 0.98rem;
        line-height: 1;
        transition: transform 140ms ease, background-color 140ms ease, border-color 140ms ease, color 140ms ease;
      }

      :global(.button.primary) {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff8f2;
      }

      :global(.button.primary:hover) {
        background: var(--accent-dark);
        border-color: var(--accent-dark);
        transform: translateY(-1px);
      }

      :global(.button.secondary:hover) {
        background: rgba(23, 20, 18, 0.05);
        transform: translateY(-1px);
      }

      :global(.home-stack) {
        display: grid;
        gap: 1.25rem;
      }

      :global(.text-hero) {
        padding: 0.35rem 0 0.7rem;
      }

      :global(.hero-note) {
        max-width: 54ch;
        font-size: 1.12rem;
      }

      :global(.section-card) {
        padding: 0.9rem;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.48);
      }

      :global(.editorial-split) {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 0.9rem;
        align-items: start;
      }

      :global(.mini-grid) {
        display: grid;
        gap: 1rem;
      }

      :global(.media-frame) {
        overflow: hidden;
        border-radius: 18px;
        border: 1px solid rgba(24, 18, 15, 0.08);
        background: #e7dfd5;
      }

      :global(.media-frame img) {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      :global(.portrait-art) {
        width: 100%;
        max-width: 190px;
        aspect-ratio: 4 / 5;
        min-height: 0;
        max-height: none;
      }

      :global(.support-art) {
        width: 100%;
        max-width: 190px;
        aspect-ratio: 4 / 3;
        min-height: 0;
        max-height: none;
      }

      :global(.media-frame.no-crop img) {
        object-fit: contain;
        background: #f3ece3;
      }

      :global(.studio-art) {
        width: 100%;
        max-width: 190px;
        aspect-ratio: 4 / 5;
        min-height: 0;
        max-height: none;
      }

      :global(.image-caption) {
        margin: 0.35rem 0 0;
        font-size: 0.84rem;
        color: var(--muted);
      }

      :global(.compact-card) {
        display: grid;
        gap: 0.35rem;
      }

      :global(.contact-stack) {
        display: grid;
        gap: 1.25rem;
      }

      :global(.contact-grid) {
        display: grid;
        gap: 1rem;
      }

      :global(.meta-line) {
        font-size: 0.9rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      :global(.section-intro) {
        max-width: 60ch;
      }

      :global(.site-form) {
        display: grid;
        gap: 0.9rem;
      }

      :global(.field-row) {
        display: grid;
        gap: 0.9rem;
      }

      :global(.field) {
        display: grid;
        gap: 0.35rem;
      }

      :global(.field label) {
        font-size: 0.95rem;
        color: var(--text);
      }

      :global(.field input),
      :global(.field select),
      :global(.field textarea) {
        width: 100%;
        padding: 0.85rem 0.95rem;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.8);
        color: var(--text);
        font: inherit;
      }

      :global(.field textarea) {
        resize: vertical;
        min-height: 10rem;
      }

      :global(.field input:focus),
      :global(.field select:focus),
      :global(.field textarea:focus) {
        outline: 2px solid rgba(222, 90, 42, 0.18);
        border-color: var(--accent);
      }

      :global(.form-note) {
        margin: 0;
        font-size: 0.95rem;
      }

      :global(.form-trap) {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }

      @media (min-width: 640px) {
        :global(.editorial-split) {
          grid-template-columns: 190px minmax(0, 1fr);
        }

        :global(.field-row) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (min-width: 760px) {
        :global(.mini-grid) {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        :global(.contact-grid) {
          grid-template-columns: 0.9fr 1.1fr;
          align-items: start;
        }

        .page-card {
          padding: 1.6rem;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header">
      <div class="header-inner">
        <a class="brand" href="/">COPE</a>
        <nav class="nav" aria-label="Main navigation">
          {navItems.map((item) => (
            <a href={item.href}>{item.label}</a>
          ))}
        </nav>
      </div>
    </header>

    <div class="page-shell">
      <div class="page-card">
        <slot />
      </div>
    </div>

    <footer class="site-footer">
      <p>COPE. Where chaos finds form. Based in Southampton, UK.</p>
    </footer>
  </body>
</html>
