---
interface Props {
  title: string;
}

const { title } = Astro.props;

const navItems = [
  { href: '/', label: 'Home' },
  {
    href: '/shop/',
    label: 'Shop',
    children: [
      { href: '/shop/art/', label: 'Shop Art' },
      { href: '/shop/apparel/', label: 'Shop Apparel' },
    ],
  },
  { href: '/murals', label: 'Murals' },
  { href: '/commissions', label: 'Commissions' },
  { href: '/about', label: 'About' },
  { href: '/contact', label: 'Contact' },
  { href: '/journal/', label: 'Journal' },
];
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <link rel="icon" type="image/png" href="/images/brand/cope-favicon.png" />
    <style>
      :root {
        color-scheme: light;
        --bg: #f4efe7;
        --text: #18120f;
        --muted: #5c5149;
        --line: #d8cabd;
        --accent: #de5a2a;
        --accent-dark: #a83a16;
        --surface: rgba(255, 252, 247, 0.82);
        --max: 1080px;
      }

      :global(*) {
        box-sizing: border-box;
      }

      :global(body) {
        margin: 0;
        font-family: Georgia, "Times New Roman", serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(222, 90, 42, 0.14), transparent 20rem),
          radial-gradient(circle at bottom right, rgba(24, 18, 15, 0.06), transparent 26rem),
          linear-gradient(180deg, #fbf7f1 0%, var(--bg) 100%);
      }

      :global(a) {
        color: inherit;
      }

      .site-header {
        position: sticky;
        top: 0;
        z-index: 10;
        backdrop-filter: blur(10px);
        background: rgba(247, 242, 232, 0.9);
        border-bottom: 1px solid var(--line);
      }

      .header-inner,
      .page-shell,
      .site-footer {
        width: min(calc(100% - 2rem), var(--max));
        margin: 0 auto;
      }

      .header-inner {
        display: flex;
        flex-wrap: wrap;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        padding: 1rem 0;
      }

      .brand {
        font-size: 1rem;
        font-weight: 700;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        text-decoration: none;
      }

      .nav {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
      }

      .nav-link {
        text-decoration: none;
        color: var(--muted);
      }

      .nav-link:hover {
        color: var(--text);
      }

      .nav-item {
        position: relative;
        display: flex;
        align-items: center;
      }

      .nav-group {
        position: relative;
      }

      .nav-summary {
        display: inline-flex;
        align-items: center;
        gap: 0.35rem;
        padding: 0;
        border: 0;
        background: transparent;
        color: var(--muted);
        font: inherit;
        cursor: pointer;
        list-style: none;
      }

      .nav-summary::-webkit-details-marker {
        display: none;
      }

      .nav-summary::after {
        content: '';
        width: 0.45rem;
        height: 0.45rem;
        border-right: 1.5px solid currentColor;
        border-bottom: 1.5px solid currentColor;
        transform: rotate(45deg) translateY(-1px);
        transition: transform 140ms ease;
      }

      .nav-group[open] .nav-summary::after {
        transform: rotate(-135deg) translateY(-1px);
      }

      .nav-summary:hover {
        color: var(--text);
      }

      .menu-toggle {
        display: none;
        align-items: center;
        justify-content: center;
        flex-direction: column;
        width: 2.9rem;
        height: 2.9rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        background: rgba(255, 252, 247, 0.92);
        color: var(--text);
        cursor: pointer;
      }

      .menu-toggle-bar {
        display: block;
        width: 1.1rem;
        height: 2px;
        border-radius: 999px;
        background: currentColor;
        transition: transform 140ms ease, opacity 140ms ease;
      }

      .menu-toggle-bar + .menu-toggle-bar {
        margin-top: 0.22rem;
      }

      .nav-dropdown {
        display: none;
        position: absolute;
        top: calc(100% + 0.55rem);
        left: 0;
        min-width: 12rem;
        padding: 0.55rem;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: #fffaf3;
        box-shadow: 0 18px 32px rgba(23, 20, 18, 0.1);
        z-index: 30;
      }

      .nav-dropdown a {
        display: block;
        padding: 0.5rem 0.7rem;
        border-radius: 10px;
        text-decoration: none;
        color: var(--muted);
      }

      .nav-dropdown a:hover {
        background: rgba(23, 20, 18, 0.04);
        color: var(--text);
      }

      .nav-group[open] .nav-dropdown {
        display: block;
      }

      .page-shell {
        padding: 2rem 0 3rem;
      }

      .page-card {
        background: var(--surface);
        border: 1px solid rgba(217, 204, 191, 0.9);
        border-radius: 20px;
        padding: 1.25rem;
        box-shadow: 0 12px 28px rgba(23, 20, 18, 0.04);
      }

      .eyebrow {
        display: inline-block;
        margin: 0 0 0.85rem;
        padding: 0.32rem 0.6rem;
        border-radius: 999px;
        font-size: 0.8rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--muted);
        background: rgba(222, 90, 42, 0.1);
      }

      :global(h1),
      :global(h2),
      :global(h3) {
        line-height: 1.06;
        margin-top: 0;
      }

      :global(h1) {
        font-size: clamp(2.7rem, 6.3vw, 5.4rem);
        max-width: 15ch;
        margin-bottom: 1.1rem;
        letter-spacing: -0.03em;
      }

      :global(h2) {
        font-size: clamp(1.7rem, 3vw, 2.35rem);
        margin-bottom: 0.7rem;
        letter-spacing: -0.02em;
      }

      :global(h3) {
        font-size: 1.1rem;
        margin-bottom: 0.4rem;
      }

      :global(p),
      :global(li) {
        font-size: 1.03rem;
        line-height: 1.68;
        color: var(--muted);
      }

      :global(ul) {
        padding-left: 1.2rem;
      }

      .site-footer {
        padding: 0 0 2rem;
        color: var(--muted);
        font-size: 0.95rem;
      }

      :global(.button-row) {
        display: flex;
        flex-wrap: wrap;
        gap: 0.85rem;
        margin: 1.35rem 0 0;
      }

      :global(.button) {
        display: inline-flex;
        align-items: center;
        justify-content: center;
        min-height: 3rem;
        padding: 0.8rem 1.28rem;
        border-radius: 999px;
        text-decoration: none;
        border: 1px solid var(--text);
        font-size: 0.98rem;
        line-height: 1;
        transition: transform 140ms ease, background-color 140ms ease, border-color 140ms ease, color 140ms ease;
      }

      :global(.button.primary) {
        background: var(--accent);
        border-color: var(--accent);
        color: #fff8f2;
      }

      :global(.button.primary:hover) {
        background: var(--accent-dark);
        border-color: var(--accent-dark);
        transform: translateY(-1px);
      }

      :global(.button.secondary:hover) {
        background: rgba(23, 20, 18, 0.05);
        transform: translateY(-1px);
      }

      :global(.home-stack) {
        display: grid;
        gap: 1.25rem;
      }

      :global(.text-hero) {
        padding: 0.35rem 0 0.7rem;
        text-align: center;
      }

      :global(.text-hero h1) {
        margin-left: auto;
        margin-right: auto;
      }

      :global(.brand-hero) {
        margin-bottom: 0.2rem;
      }

      :global(.brand-hero-image) {
        width: 100%;
        min-height: 16rem;
        border-radius: 26px;
      }

      :global(.brand-hero-image img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
        object-position: center;
      }

      :global(.hero-note) {
        max-width: 54ch;
        font-size: 1.12rem;
        margin-left: auto;
        margin-right: auto;
      }

      :global(.text-hero .button-row) {
        justify-content: center;
      }

      :global(.section-card) {
        padding: 0.9rem;
        border: 1px solid var(--line);
        border-radius: 16px;
        background: rgba(255, 255, 255, 0.48);
      }

      :global(.editorial-split) {
        display: grid;
        grid-template-columns: minmax(0, 1fr);
        gap: 0.9rem;
        align-items: start;
      }

      :global(.mini-grid) {
        display: grid;
        gap: 1rem;
      }

      :global(.shop-grid) {
        display: grid;
        gap: 1rem;
      }

      :global(.shop-section) {
        display: grid;
        gap: 1rem;
        margin-top: 2rem;
      }

      :global(.shop-overview-grid) {
        margin-top: 1.25rem;
      }

      :global(.media-frame) {
        overflow: hidden;
        border-radius: 18px;
        border: 1px solid rgba(24, 18, 15, 0.08);
        background: #e7dfd5;
      }

      :global(.media-frame img) {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      :global(.portrait-art) {
        width: 100%;
        max-width: 190px;
        aspect-ratio: 4 / 5;
        min-height: 0;
        max-height: none;
      }

      :global(.support-art) {
        width: 100%;
        max-width: 190px;
        aspect-ratio: 4 / 3;
        min-height: 0;
        max-height: none;
      }

      :global(.media-frame.no-crop img) {
        object-fit: contain;
        background: #f3ece3;
      }

      :global(.studio-art) {
        width: 100%;
        max-width: 190px;
        aspect-ratio: 4 / 5;
        min-height: 0;
        max-height: none;
      }

      :global(.image-caption) {
        margin: 0.35rem 0 0;
        font-size: 0.84rem;
        color: var(--muted);
      }

      :global(.compact-card) {
        display: grid;
        gap: 0.35rem;
      }

      :global(.contact-stack) {
        display: grid;
        gap: 1.25rem;
      }

      :global(.contact-grid) {
        display: grid;
        gap: 1rem;
      }

      :global(.meta-line) {
        font-size: 0.9rem;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        color: var(--muted);
      }

      :global(.section-intro) {
        max-width: 60ch;
      }

      :global(.shop-card) {
        padding: 0.8rem;
      }

      :global(.shop-card-link) {
        display: grid;
        gap: 0.85rem;
        text-decoration: none;
      }

      :global(.shop-art) {
        width: 100%;
        aspect-ratio: 4 / 5;
        min-height: 23rem;
        max-height: 23rem;
      }

      :global(.shop-art img) {
        object-fit: contain;
        background: #ffffff;
      }

      :global(.shop-apparel-art) {
        min-height: 19rem;
        max-height: 19rem;
        background: #f7f1e8;
      }

      :global(.shop-apparel-art img) {
        background: #f7f1e8;
      }

      :global(.shop-copy) {
        display: grid;
        gap: 0.18rem;
      }

      :global(.product-meta) {
        display: grid;
        gap: 0.05rem;
        margin: 0.15rem 0 0.35rem;
      }

      :global(.product-meta p) {
        margin: 0;
        line-height: 1.35;
      }

      :global(.shop-copy h2) {
        font-size: 1.45rem;
        margin-bottom: 0.25rem;
      }

      :global(.shop-link-note) {
        margin-top: 0.4rem;
        color: var(--accent-dark);
      }

      :global(.product-stack) {
        display: grid;
        gap: 1rem;
      }

      :global(.back-link) {
        color: var(--muted);
        text-decoration: none;
      }

      :global(.back-link:hover) {
        color: var(--text);
      }

      :global(.product-layout) {
        display: grid;
        gap: 1rem;
      }

      :global(.product-gallery) {
        display: grid;
        gap: 0.9rem;
      }

      :global(.product-main-image) {
        width: 100%;
        min-height: 22rem;
        padding: 0;
        cursor: zoom-in;
      }

      :global(.product-main-image img) {
        width: 100%;
        height: 100%;
        object-fit: contain;
        background: #f4efe7;
      }

      :global(.product-thumbnails) {
        display: grid;
        gap: 0.8rem;
        grid-template-columns: repeat(auto-fit, minmax(110px, 1fr));
      }

      :global(.lightbox) {
        position: fixed;
        inset: 0;
        z-index: 60;
        display: grid;
        place-items: center;
        padding: 1rem;
      }

      :global(.lightbox[hidden]) {
        display: none !important;
      }

      :global(.lightbox-backdrop) {
        position: absolute;
        inset: 0;
        background: rgba(18, 14, 12, 0.84);
        backdrop-filter: blur(4px);
      }

      :global(.lightbox-dialog) {
        position: relative;
        z-index: 1;
        width: min(100%, 980px);
        display: grid;
        gap: 0.75rem;
      }

      :global(.lightbox-close) {
        justify-self: end;
        width: 3rem;
        height: 3rem;
        border: 1px solid rgba(255, 255, 255, 0.35);
        border-radius: 999px;
        background: rgba(255, 252, 247, 0.92);
        color: var(--text);
        font-size: 1.8rem;
        line-height: 1;
        cursor: pointer;
      }

      :global(.lightbox-frame) {
        border-radius: 22px;
        overflow: hidden;
        background: #fff;
        border: 1px solid rgba(255, 255, 255, 0.16);
        box-shadow: 0 18px 42px rgba(0, 0, 0, 0.22);
      }

      :global(.lightbox-frame img) {
        display: block;
        width: 100%;
        max-height: min(78vh, 980px);
        object-fit: contain;
        background: #fff;
      }

      :global(.thumb-button) {
        display: grid;
        gap: 0.3rem;
        padding: 0;
        border: 0;
        background: transparent;
        text-align: left;
        cursor: pointer;
      }

      :global(.thumb-button.is-active .thumb-frame) {
        border-color: rgba(222, 90, 42, 0.75);
        box-shadow: 0 0 0 2px rgba(222, 90, 42, 0.12);
      }

      :global(.thumb-frame) {
        aspect-ratio: 1 / 1;
      }

      :global(.thumb-frame img) {
        width: 100%;
        height: 100%;
        object-fit: cover;
      }

      :global(.thumb-caption) {
        font-size: 0.88rem;
        color: var(--muted);
      }

      :global(.site-form) {
        display: grid;
        gap: 0.9rem;
      }

      :global(.field-row) {
        display: grid;
        gap: 0.9rem;
      }

      :global(.field) {
        display: grid;
        gap: 0.35rem;
      }

      :global(.field label) {
        font-size: 0.95rem;
        color: var(--text);
      }

      :global(.field input),
      :global(.field select),
      :global(.field textarea) {
        width: 100%;
        padding: 0.85rem 0.95rem;
        border-radius: 14px;
        border: 1px solid var(--line);
        background: rgba(255, 255, 255, 0.8);
        color: var(--text);
        font: inherit;
      }

      :global(.field textarea) {
        resize: vertical;
        min-height: 10rem;
      }

      :global(.field input:focus),
      :global(.field select:focus),
      :global(.field textarea:focus) {
        outline: 2px solid rgba(222, 90, 42, 0.18);
        border-color: var(--accent);
      }

      :global(.form-note) {
        margin: 0;
        font-size: 0.95rem;
      }

      :global(.form-trap) {
        position: absolute;
        left: -9999px;
        width: 1px;
        height: 1px;
        overflow: hidden;
      }

      :global(.form-error) {
        margin: 0;
        padding: 0.8rem 0.95rem;
        border-radius: 12px;
        background: rgba(168, 58, 22, 0.08);
        border: 1px solid rgba(168, 58, 22, 0.2);
        color: var(--accent-dark);
      }

      :global(.success-panel) {
        display: grid;
        gap: 0.65rem;
        padding: 0.25rem 0;
      }

      :global(.success-panel[hidden]),
      :global(.form-error[hidden]) {
        display: none !important;
      }

      @media (min-width: 640px) {
        :global(.editorial-split) {
          grid-template-columns: 190px minmax(0, 1fr);
        }

        :global(.field-row) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }
      }

      @media (min-width: 760px) {
        :global(.mini-grid) {
          grid-template-columns: repeat(2, minmax(0, 1fr));
        }

        :global(.shop-grid) {
          grid-template-columns: repeat(3, minmax(0, 1fr));
        }

        :global(.brand-hero-image) {
          min-height: 21rem;
        }

        :global(.contact-grid) {
          grid-template-columns: 0.9fr 1.1fr;
          align-items: start;
        }

        :global(.product-layout) {
          grid-template-columns: minmax(0, 1.05fr) minmax(0, 0.95fr);
          align-items: start;
        }

        .page-card {
          padding: 1.6rem;
        }
      }

      @media (max-width: 759px) {
        .header-inner {
          align-items: center;
          position: relative;
        }

        .menu-toggle {
          display: inline-flex;
        }

        .nav {
          display: none;
          position: absolute;
          top: calc(100% + 0.75rem);
          left: 0;
          right: 0;
          z-index: 20;
          padding: 0.85rem 1rem 0.95rem;
          border: 1px solid var(--line);
          border-radius: 22px;
          background: #fffaf3;
          box-shadow: 0 20px 36px rgba(23, 20, 18, 0.12);
          flex-direction: column;
          gap: 0.35rem;
        }

        .nav-item,
        .nav-group {
          display: grid;
          gap: 0.15rem;
        }

        .nav-link {
          padding: 0.08rem 0;
          font-size: 0.95rem;
        }

        .nav-summary {
          justify-content: start;
          font-size: 0.95rem;
          padding: 0.08rem 0;
        }

        .nav-dropdown {
          display: grid;
          position: static;
          min-width: auto;
          padding: 0 0 0 0.85rem;
          border: 0;
          border-radius: 0;
          background: transparent;
          box-shadow: none;
        }

        .nav-dropdown a {
          padding: 0.08rem 0;
          font-size: 0.92rem;
        }

        .site-header.is-open .nav {
          display: flex;
        }

        .site-header.is-open .menu-toggle-bar:nth-child(1) {
          transform: translateY(4px) rotate(45deg);
        }

        .site-header.is-open .menu-toggle-bar:nth-child(2) {
          opacity: 0;
        }

        .site-header.is-open .menu-toggle-bar:nth-child(3) {
          transform: translateY(-4px) rotate(-45deg);
        }

        :global(.brand-hero-image) {
          min-height: 9.5rem;
        }

        :global(.brand-hero-image img) {
          object-fit: contain;
          background: #fbf7f1;
        }
      }
    </style>
  </head>
  <body>
    <header class="site-header" id="site-header">
      <div class="header-inner">
        <a class="brand" href="/">COPE</a>
        <button
          class="menu-toggle"
          id="menu-toggle"
          type="button"
          aria-expanded="false"
          aria-controls="site-nav"
          aria-label="Toggle navigation"
        >
          <span class="menu-toggle-bar"></span>
          <span class="menu-toggle-bar"></span>
          <span class="menu-toggle-bar"></span>
        </button>
        <nav class="nav" id="site-nav" aria-label="Main navigation">
          {navItems.map((item) => (
            item.children ? (
              <details class="nav-group">
                <summary class="nav-summary">{item.label}</summary>
                <div class="nav-dropdown">
                  <a href={item.href}>Shop Overview</a>
                  {item.children.map((child) => (
                    <a href={child.href}>{child.label}</a>
                  ))}
                </div>
              </details>
            ) : (
              <div class="nav-item">
                <a class="nav-link" href={item.href}>{item.label}</a>
              </div>
            )
          ))}
        </nav>
      </div>
    </header>

    <div class="page-shell">
      <div class="page-card">
        <slot />
      </div>
    </div>

    <footer class="site-footer">
      <p>COPE. Where chaos finds form. Based in Southampton, UK.</p>
    </footer>

    <script is:inline>
      const header = document.getElementById('site-header');
      const menuToggle = document.getElementById('menu-toggle');
      const siteNav = document.getElementById('site-nav');

      if (header && menuToggle && siteNav) {
        const navGroups = siteNav.querySelectorAll('.nav-group');

        menuToggle.addEventListener('click', () => {
          const isOpen = header.classList.toggle('is-open');
          menuToggle.setAttribute('aria-expanded', isOpen ? 'true' : 'false');
        });

        siteNav.querySelectorAll('a').forEach((link) => {
          link.addEventListener('click', () => {
            header.classList.remove('is-open');
            menuToggle.setAttribute('aria-expanded', 'false');
            navGroups.forEach((group) => group.removeAttribute('open'));
          });
        });

        document.addEventListener('click', (event) => {
          if (!header.contains(event.target)) {
            navGroups.forEach((group) => group.removeAttribute('open'));
          }
        });
      }
    </script>
  </body>
</html>
